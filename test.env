# Test environment configuration
# Used by pytest (via conftest.py) and Playwright (via --config test.env).
# Do NOT use in production.

TESTING=True
SECRET_KEY=test-secret-key
WTF_CSRF_ENABLED=False
ENABLE_TEST_ROUTES=1

# Flask server settings (Playwright webServer)
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5005

# Database (pytest overrides SQLALCHEMY_DATABASE_URI with a per-session
# temporary file; Playwright uses this fixed path)
DATABASE_TYPE=sqlite
SQLITE_PATH=./test-expenses.db
