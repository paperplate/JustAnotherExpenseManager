{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "JustAnotherExpenseManager/static/js",
    "rootDir": "static_src",
    "removeComments": false,
    "noEmitOnError": true
  },
  "include": [
    "static_src/**/*.ts"
  ]
}
